# Environment
ENVIRONMENT=development
DEBUG=true

# Hadoop Configuration
HADOOP_VERSION=3.2.1
HDFS_NAMENODE_PORT=9000
HDFS_NAMENODE_HTTP_PORT=9870
HDFS_DATANODE_PORT=9866
HDFS_DATANODE_HTTP_PORT=9864
HDFS_REPLICATION=1
CLUSTER_NAME=test-cluster

# Spark Configuration
SPARK_VERSION=3.5.0  # 👈 Синхронизируйте с docker-compose
SPARK_MASTER_HOST=172.22.0.4
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_WEBUI_PORT=8081
SPARK_WORKER_PORT=7081

# Application Configuration
APP_NAME=SalesETL
# 👇 УВЕЛИЧЕНО: Больше памяти для воркеров
EXECUTOR_MEMORY=2g        # Было 1g → Стало 2g
DRIVER_MEMORY=2g           # Было 1g → Стало 2g
EXECUTOR_CORES=2           # Было 1  → Стало 2
DRIVER_CORES=2             # Было 1  → Стало 2


# 👇 ДОБАВЛЕНО: Настройки Spark для стабильной работы
SPARK_WORKER_MEMORY=2g     # Память на каждый worker
SPARK_WORKER_CORES=2       # Ядра на каждый worker
SPARK_EXECUTOR_MEMORY=2g   # Память executor'а
SPARK_DEFAULT_PARALLELISM=4 # Параллелизм по умолчанию
SPARK_SQL_SHUFFLE_PARTITIONS=4 # Партиции для shuffle

# Network Configuration
SUBNET=172.22.0.0/24
GATEWAY=172.22.0.1

# Jupyter Configuration
JUPYTER_PORT=8888
JUPYTER_TOKEN=etl2024

# Data Paths
DATA_VOLUME=./data
LOGS_VOLUME=./logs
NOTEBOOKS_VOLUME=./notebooks