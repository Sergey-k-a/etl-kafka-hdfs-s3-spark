<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property>
        <name>dfs.replication</name>
        <value>1</value>
    </property>
    <property>
        <name>dfs.namenode.name.dir</name>
        <value>/hadoop/dfs/name</value>
    </property>
    
    <!-- ОТКЛЮЧАЕМ ПРОВЕРКУ HOSTNAME -->
    <property>
        <name>dfs.namenode.datanode.registration.ip-hostname-check</name>
        <value>false</value>
    </property>
    
    <!-- ОСНОВНЫЕ АДРЕСА - используем IP -->
    <property>
        <name>dfs.namenode.rpc-address</name>
        <value>172.22.0.2:9000</value>
    </property>
    <property>
        <name>dfs.namenode.http-address</name>
        <value>172.22.0.2:9870</value>
    </property>
    
    <!-- BIND АДРЕСА - используем 0.0.0.0 для слушания, но адреса указываем конкретные -->
    <property>
        <name>dfs.namenode.rpc-bind-host</name>
        <value>0.0.0.0</value>
    </property>
    <property>
        <name>dfs.namenode.http-bind-host</name>
        <value>0.0.0.0</value>
    </property>
    
    <!-- ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ ДЛЯ IP -->
    <property>
        <name>dfs.client.use.datanode.hostname</name>
        <value>false</value>
    </property>
    <property>
        <name>dfs.datanode.use.datanode.hostname</name>
        <value>false</value>
    </property>
    
    <property>
        <name>dfs.permissions.enabled</name>
        <value>false</value>
    </property>
</configuration>